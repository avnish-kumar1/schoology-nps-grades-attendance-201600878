 || elem === 0) {\n                            if ( jQuery.type( elem ) !== \"object\" && rhtml.test( elem ) ) {\n                                elems[i] = elem = jQuery.htmlPrefilter(elem);\n                            }\n                        }\n                    }\n                    return originalBuildFragment.call(this, elems, context, scripts, selection);\n                }\n            });\n        }\n    }\n\n})(jQuery);"},function(t,e,n){n(3)(n(14))},function(t,e){t.exports="\n(function($){var escapeable=/[\"\\\\\\x00-\\x1f\\x7f-\\x9f]/g,meta={'\\b':'\\\\b','\\t':'\\\\t','\\n':'\\\\n','\\f':'\\\\f','\\r':'\\\\r','\"':'\\\\\"','\\\\':'\\\\\\\\'};$.toJSON=typeof JSON==='object'&&JSON.stringify?JSON.stringify:function(o){if(o===null){return'null';}\nvar type=typeof o;if(type==='undefined'){return undefined;}\nif(type==='number'||type==='boolean'){return''+o;}\nif(type==='string'){return $.quoteString(o);}\nif(type==='object'){if(typeof o.toJSON==='function'){return $.toJSON(o.toJSON());}\nif(o.constructor===Date){var month=o.getUTCMonth()+1,day=o.getUTCDate(),year=o.getUTCFullYear(),hours=o.getUTCHours(),minutes=o.getUTCMinutes(),seconds=o.getUTCSeconds(),milli=o.getUTCMilliseconds();if(month<10){month='0'+month;}\nif(day<10){day='0'+day;}\nif(hours<10){hours='0'+hours;}\nif(minutes<10){minutes='0'+minutes;}\nif(seconds<10){seconds='0'+seconds;}\nif(milli<100){milli='0'+milli;}\nif(milli<10){milli='0'+milli;}\nreturn'\"'+year+'-'+month+'-'+day+'T'+\nhours+':'+minutes+':'+seconds+'.'+milli+'Z\"';}\nif(o.constructor===Array){var ret=[];for(var i=0;i<o.length;i++){ret.push($.toJSON(o[i])||'null');}\nreturn'['+ret.join(',')+']';}\nvar name,val,pairs=[];for(var k in o){type=typeof k;if(type==='number'){name='\"'+k+'\"';}else if(type==='string'){name=$.quoteString(k);}else{continue;}\ntype=typeof o[k];if(type==='function'||type==='undefined'){continue;}\nval=$.toJSON(o[k]);pairs.push(name+':'+val);}\nreturn'{'+pairs.join(',')+'}';}};$.evalJSON=typeof JSON==='object'&&JSON.parse?JSON.parse:function(src){return eval('('+src+')');};$.secureEvalJSON=typeof JSON==='object'&&JSON.parse?JSON.parse:function(src){var filtered=src.replace(/\\\\[\"\\\\\\/bfnrtu]/g,'@').replace(/\"[^\"\\\\\\n\\r]*\"|true|false|null|-?\\d+(?:\\.\\d*)?(?:[eE][+\\-]?\\d+)?/g,']').replace(/(?:^|:|,)(?:\\s*\\[)+/g,'');if(/^[\\],:{}\\s]*$/.test(filtered)){return eval('('+src+')');}else{throw new SyntaxError('Error parsing JSON, source is not valid.');}};$.quoteString=function(string){if(string.match(escapeable)){return'\"'+string.replace(escapeable,function(a){var c=meta[a];if(typeof c==='string'){return c;}\nc=a.charCodeAt();return'\\\\u00'+Math.floor(c/16).toString(16)+(c%16).toString(16);})+'\"';}\nreturn'\"'+string+'\"';};})(jQuery);"},function(t,e,n){n(3)(n(16))},function(t,e){t.exports="/*\n * Action Links\n * A Tool that allows a sec of buttons to be displayed by a gear\n * and contain a dropdown of user choices\n * Created: by Jeremy Friedman 12/24/2009\n *\n * Update: the s_actionlinks_hide event has been removed.  It is never listened for and\n * was preventing the onbeforeunload event from firing in the gradebook.\n *\n * Update: Added keyboard navigation and accessibility improvements for WCAG compliance\n *\n */\nvar sActionLinkBodySet = false;\nvar sActionLinkBodySet2 = false;\n\n(function($) {\n  var KEY_ENTER = 13;\n  var KEY_SPACE = 32;\n  var KEY_ESCAPE = 27;\n  var KEY_TAB = 9;\n  var KEY_ARROW_UP = 38;\n  var KEY_ARROW_DOWN = 40;\n\n  var MENU_ITEM_SELECTOR = 'a, button, [role=\"menuitem\"], [role=\"button\"][tabindex]';\n\n  function findFocusableInLi($li) {\n    if ($li.is(MENU_ITEM_SELECTOR)) {\n      return $li;\n    }\n    return $li.find(MENU_ITEM_SELECTOR).first();\n  }\n\n  function closeMenuInWrapper($wrapper) {\n    if (!$wrapper.length) return null;\n    var $trigger = $wrapper.find('.action-links-unfold').first();\n    var $menu = $wrapper.find('.action-links').first();\n    $menu.find('li').removeClass('hover');\n    $trigger.removeClass('active').attr('aria-expanded', 'false');\n    $menu.hide();\n    $wrapper.find('.sActionLinksVisible').removeClass('sActionLinksVisible');\n    return $trigger;\n  }\n\n  if (!sActionLinkBodySet2) {\n    sActionLinkBodySet2 = true;\n    $(document).on('keydown.sactionlinks-menu', '.action-links-wrapper .action-links', function(e) {\n      var $target = $(e.target);\n      var key = e.keyCode || e.which;\n\n      if (key === KEY_ARROW_DOWN || key === KEY_ARROW_UP) {\n        e.preventDefault();\n        var $currentLi = $target.closest('li');\n        if (!$currentLi.length) return;\n        var $siblings = $currentLi.parent().children('li');\n        var idx = $siblings.index($currentLi);\n        var $targetLi = (key === KEY_ARROW_DOWN)\n          ? $siblings.eq((idx + 1) % $siblings.length)\n          : $siblings.eq((idx - 1 + $siblings.length) % $siblings.length);\n        $currentLi.closest('.action-links').find('li').removeClass('hover');\n        var $focusable = findFocusableInLi($targetLi);\n        if ($focusable.length) {\n          $focusable.focus();\n          $targetLi.addClass('hover');\n        }\n      }\n      else if (key === KEY_ESCAPE || key === KEY_TAB) {\n        var $wrapper = $target.closest('.action-links-wrapper');\n        var $trigger = closeMenuInWrapper($wrapper);\n        if (key === KEY_ESCAPE && $trigger && $trigger.length) {\n          e.preventDefault();\n          $trigger.focus();\n        }\n      }\n      else if ((key === KEY_ENTER || key === KEY_SPACE) && !$target.is('a')) {\n        e.preventDefault();\n        $target[0].click();\n        closeMenuInWrapper($target.closest('.action-links-wrapper'));\n      }\n    });\n  }\n\n  $.fn.sActionLinks = function(options) {\n    var opts = $.extend( {}, $.fn.sActionLinks.defaults, options);\n\n    if( opts.hide_all ){\n      $(\".action-links-unfold\").removeClass('active').next().hide();\n      $(\".sActionLinksVisible\").removeClass('sActionLinksVisible')\n      return;\n    }\n\n    // determine if the gears are hidden or shown by default\n    var hidden = options.hidden;\n\n    // determine if there is a custom wrapper element we can use\n    var wrapper = options.wrapper;\n    var rowClass = options.rowClass;\n    var item = $(this);\n\n    if (hidden && opts.onTargetSelector == '') {\n      item.unbind('mouseenter').bind('mouseenter', function(e) {\n        var element = $(this);\n\n        if (wrapper.length > 0) $(wrapper, element).addClass('sActionLinksVisible');\n      });\n\n      item.unbind('mouseleave').bind('mouseleave', function() {\n        var element = $(this);\n\n        if (!$(\".action-links\", element).is(\":visible\")) {\n          if (wrapper.length > 0) $(wrapper, element).removeClass('sActionLinksVisible');\n          $(\".action-links\", element).hide();\n        }\n      }).trigger('mouseleave');\n    }\n\n    // save opts\n    $(\".action-links-unfold\").data('s_actionlinks_opts', opts);\n\n    // click actions\n    if(opts.onTargetSelector != '') {\n      // the item is the container, use delegated events\n      $(item).off('click.sactionlinks')\n        .on('click.sactionlinks', opts.onTargetSelector + ' .action-links-unfold', clickActionLinksUnfold)\n        .on('click.sactionlinks', opts.onTargetSelector + ' .action-links a', clickActionLinks)\n        .on('keydown.sactionlinks', opts.onTargetSelector + ' .action-links-unfold', handleKeydown)\n        .on('keydown.sactionlinks', opts.onTargetSelector + ' .action-links a', handleKeydown);\n    }\n    else {\n      $(\".action-links-unfold\", item).unbind('click.sactionlinks keydown.sactionlinks')\n        .bind('click.sactionlinks', clickActionLinksUnfold).bind('keydown.sactionlinks', handleKeydown);\n      $(\".action-links a\", item).unbind('click.sactionlinks keydown.sactionlinks')\n        .bind('click.sactionlinks', clickActionLinks).bind('keydown.sactionlinks', handleKeydown);\n    }\n\n    /*\n     * Handle keydown events for trigger and link items\n     */\n    function handleKeydown(e) {\n      var $target = $(e.target);\n      var key = e.keyCode || e.which;\n\n      switch(key) {\n        case KEY_ENTER:\n        case KEY_SPACE:\n          if ($target.hasClass('action-links-unfold')) {\n            e.preventDefault();\n            clickActionLinksUnfold.call($target[0], e);\n            focusFirstElement(e);\n          } else if ($target.is('a')) {\n            if (key === KEY_SPACE) {\n              e.preventDefault();\n            }\n            clickActionLinks.call($target[0], e);\n          }\n          break;\n        case KEY_ESCAPE:\n          e.preventDefault();\n          var $trigger = $target.closest('.action-links-wrapper').find('.action-links-unfold').first();\n          closeAllDropdowns(e);\n          if ($trigger.length) $trigger.focus();\n          break;\n        case KEY_TAB:\n          closeAllDropdowns(e);\n          break;\n        case KEY_ARROW_DOWN:\n          if ($target.hasClass('action-links-unfold')) {\n            e.preventDefault();\n            if (!$target.hasClass('active')) {\n              clickActionLinksUnfold.call($target[0], e);\n            }\n            focusFirstElement(e);\n          }\n          break;\n        case KEY_ARROW_UP:\n          if ($target.hasClass('action-links-unfold')) {\n            e.preventDefault();\n            if (!$target.hasClass('active')) {\n              clickActionLinksUnfold.call($target[0], e);\n            }\n            focusLastElement(e);\n          }\n          break;\n      }\n    }\n\n    /*\n     * Close all dropdowns\n     */\n    function closeAllDropdowns(e) {\n      clearHoverActionLinks();\n      $(\".action-links-unfold\").attr(\"aria-expanded\", \"false\").removeClass('active').next().hide();\n      $(\".sActionLinksVisible\").removeClass('sActionLinksVisible');\n    }\n\n    /*\n     * Focus the first menu item after opening\n     */\n    function focusFirstElement(e) {\n      var $trigger = $(e.targ